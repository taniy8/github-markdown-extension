{
  "manifest_version": 3,
  "name": "GitHub Markdown Formatter",
  "version": "1.0.0",
  "description": "Format messy developer notes into clean GitHub Markdown directly in PR descriptions and comments.",
  "permissions": ["activeTab"],
  "host_permissions": [
    "https://github.com/*",
    "https://github-markdown-formatter.vercel.app/*"
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "github-markdown-formatter@taniy8",
      "strict_min_version": "140.0",
      "data_collection_permissions": {
        "required": ["none"],
        "optional": []
      }
    }
  },
  "content_scripts": [
    {
      "matches": [
        "https://github.com/*"
      ],
      "js": ["formatter.js", "content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
